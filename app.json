{
  "expo": {
    "name": "SEEN by CREOVA",
    "slug": "seen-by-creova",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seen",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.creova.seen"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.creova.seen"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "router": {
      "root": "app"
    }
  }
}
